# Environment variables (copy to .env at repo root)
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/inventory_intelligence

# Backend
PORT=3000

# AWS
AWS_REGION=us-east-1

# AI Assistant / explanations
# ANTHROPIC_API_KEY=
# CLAUDE_MODEL=claude-3-5-sonnet-20241022

# Recommendation engine cron (Pipeline 3 / Cron B)
# Runs every 5 minutes by default. Set to false to disable.
RECOMMENDATION_CRON_ENABLED=true
RECOMMENDATION_CRON_EXPRESSION=*/5 * * * *
# Optional: scope scheduled runs to one dark store
# RECOMMENDATION_CRON_DARK_STORE_ID=

# Phase 2 — Sales optimization cron (every 15 minutes)
SALES_OPT_CRON_ENABLED=true
SALES_OPT_CRON_EXPRESSION=*/15 * * * *
# SALES_OPT_CRON_DARK_STORE_ID=
